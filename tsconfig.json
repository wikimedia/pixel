{
	"include": [
		"src",
		"config.js",
		"tests/util/fastForwardAnimations.js"
	],
	"exclude": [
		"src/engine-scripts",
		"report"
	],
	"compilerOptions": {
		"lib": [
			"es2021"
		],
		"module": "commonjs",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"sourceMap": true,
		"target": "es2021",
		"outDir": "dist",
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"pretty": true
	}
}
